{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "dist",
    "types": ["node"]
  },
  "include": [
    "bin/**/*.ts",
    "config/**/*.ts",
    "lib/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts"
  ]
}
